import Layout from "../layouts/Layout.astro";
import { fetchEmpireData } from "../lib/ordum-data";
import ResourceTable from "../components/ResourceTable.astro";
import MembersTable from "../components/MembersTable.astro";
import StatCard from "../components/StatCard.astro";

const empire = await fetchEmpireData();
const mainClaim = empire.claims[0]; // Ordum City (leader)
---

<Layout title="Ordum Empire Dashboard" activePage="dashboard">
  <!-- Header -->
  <div class="page-header">
    <h1>👑 Ordum Empire</h1>
    <p class="subtitle">
      Last updated: {
        new Date(empire.fetched_at).toLocaleString("en-US", {
          dateStyle: "medium",
          timeStyle: "short",
        })
      }
      · {empire.claims.length} claim{empire.claims.length > 1 ? "s" : ""}
    </p>
  </div>

  <!-- Summary Stats -->
  <div class="stats-grid">
    <StatCard
      label="Total Members"
      value={empire.totals.total_members}
      icon="👥"
      accent="var(--accent)"
    />
    <StatCard
      label="Online Now"
      value={empire.totals.online_members}
      icon="🟢"
      accent="var(--accent-3)"
    />
    <StatCard
      label="Buildings"
      value={empire.totals.total_buildings}
      icon="🏠"
      accent="var(--accent-2)"
    />
    <StatCard
      label="Building Resources"
      value={empire.totals.total_building_resource_count}
      icon="📦"
      accent="var(--accent-4)"
    />
    <StatCard
      label="Player Resources"
      value={empire.totals.total_player_resource_count}
      icon="🎒"
      accent="var(--accent)"
    />
    <StatCard
      label="Resource Types"
      value={empire.totals.total_building_resource_types +
        empire.totals.total_player_resource_types}
      icon="📋"
      accent="var(--accent-2)"
    />
    <StatCard
      label="Tools"
      value={empire.totals.total_tool_count}
      icon="⛏️"
      accent="var(--accent-3)"
    />
    <StatCard
      label="Treasury"
      value={mainClaim ? mainClaim.treasury : "—"}
      icon="💰"
      accent="var(--accent-4)"
    />
  </div>

  <!-- Per-Claim Sections -->
  {
    empire.claims.map((c, i) => (
      <div class="claim-section">
        <div class="claim-bar">
          <div class="claim-title-area">
            <span class="claim-icon">{i === 0 ? "👑" : "🏰"}</span>
            <h2 class="claim-name">{c.name}</h2>
            <span class="tier-badge">Tier {c.tier ?? "?"}</span>
          </div>
          <div class="claim-meta">
            <div class="meta-item">
              🗺️ <span>{c.region}</span>
            </div>
            <div class="meta-item">
              📦 <span>{c.supplies.toLocaleString()} supplies</span>
            </div>
            <div class="meta-item">
              💰 <span>{c.treasury.toLocaleString()} gold</span>
            </div>
            <div class="meta-item">
              🧱 <span>{c.num_tiles.toLocaleString()} tiles</span>
            </div>
            <div class="meta-item">
              🏠 <span>{c.building_count} buildings</span>
            </div>
            <div class="meta-item">
              👥 <span>{c.member_count} members</span>
            </div>
          </div>
        </div>

        <div class="tabs-container">
          <div class="tabs" data-claim={String(i)}>
            <button class="tab-btn active" data-tab={`buildings-${i}`}>
              <span class="tab-icon">🏠</span> Building Storage
            </button>
            <button class="tab-btn" data-tab={`players-${i}`}>
              <span class="tab-icon">🎒</span> Player Inventory
            </button>
            <button class="tab-btn" data-tab={`tools-${i}`}>
              <span class="tab-icon">⛏️</span> Tools
            </button>
            <button class="tab-btn" data-tab={`members-${i}`}>
              <span class="tab-icon">👥</span> Members
            </button>
          </div>
        </div>

        <div class="tab-panel active" id={`buildings-${i}`}>
          <ResourceTable
            title="Building Storage"
            resources={c.building_resources}
            showLocations={true}
            id={`building-res-${i}`}
          />
        </div>

        <div class="tab-panel" id={`players-${i}`}>
          <ResourceTable
            title="Online Player Inventory"
            resources={c.player_resources}
            showLocations={true}
            id={`player-res-${i}`}
          />
          <div style="height: 16px;" />
          <ResourceTable
            title="Offline Player Inventory"
            resources={c.player_offline_resources}
            showLocations={true}
            id={`offline-res-${i}`}
          />
        </div>

        <div class="tab-panel" id={`tools-${i}`}>
          <ResourceTable
            title="Online Player Tools"
            resources={c.tool_resources}
            id={`tools-online-${i}`}
          />
          <div style="height: 16px;" />
          <ResourceTable
            title="Offline Player Tools"
            resources={c.tool_offline_resources}
            id={`tools-offline-${i}`}
          />
        </div>

        <div class="tab-panel" id={`members-${i}`}>
          <MembersTable members={c.members} claimName={c.name} />
        </div>
      </div>
    ))
  }

  <!-- Empire-wide Aggregates -->
  {
    empire.claims.length > 1 && (
      <div class="claim-section">
        <div class="claim-bar empire-bar">
          <div class="claim-title-area">
            <span class="claim-icon">🌐</span>
            <h2 class="claim-name">Empire-Wide Totals</h2>
          </div>
        </div>

        <div class="tabs-container">
          <div class="tabs" data-claim="empire">
            <button class="tab-btn active" data-tab="empire-buildings">
              <span class="tab-icon">🏠</span> All Building Resources
            </button>
            <button class="tab-btn" data-tab="empire-players">
              <span class="tab-icon">🎒</span> All Player Resources
            </button>
            <button class="tab-btn" data-tab="empire-tools">
              <span class="tab-icon">⛏️</span> All Tools
            </button>
          </div>
        </div>

        <div class="tab-panel active" id="empire-buildings">
          <ResourceTable
            title="All Building Resources (Empire)"
            resources={empire.all_building_resources}
            id="empire-building-res"
          />
        </div>

        <div class="tab-panel" id="empire-players">
          <ResourceTable
            title="All Player Resources (Empire)"
            resources={empire.all_player_resources}
            id="empire-player-res"
          />
        </div>

        <div class="tab-panel" id="empire-tools">
          <ResourceTable
            title="All Tools (Empire)"
            resources={empire.all_tool_resources}
            id="empire-tool-res"
          />
        </div>
      </div>
    )
  }
</Layout>

<style>
  /* Page Header */
  .page-header {
    text-align: center;
    padding: 8px 0 12px;
    margin-bottom: 12px;
  }
  .page-header h1 {
    font-size: 1.3rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 4px;
    letter-spacing: -0.5px;
  }
  .page-header .subtitle {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 10px;
    margin-bottom: 16px;
  }

  /* Claim Section & Bar */
  .claim-section {
    margin-bottom: 24px;
  }
  .claim-bar {
    background: rgba(26, 31, 46, 0.6);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px 16px;
    margin-bottom: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  .empire-bar {
    background: linear-gradient(
      135deg,
      rgba(108, 140, 255, 0.1),
      rgba(26, 31, 46, 0.6)
    );
    border-color: rgba(108, 140, 255, 0.2);
  }

  .claim-title-area {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .claim-icon {
    font-size: 1.3rem;
    line-height: 1;
  }
  .claim-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }
  .tier-badge {
    background: var(--bg-surface-3);
    color: var(--accent-4);
    border: 1px solid rgba(251, 191, 36, 0.3);
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .claim-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .meta-item span {
    color: var(--text);
    font-weight: 500;
  }

  /* Tabs */
  .tabs-container {
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
    padding: 0 8px;
  }
  .tabs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
  }
  .tabs::-webkit-scrollbar {
    display: none;
  } /* Chrome */

  .tab-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 8px 16px;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    border-bottom: 3px solid transparent;
    margin-bottom: -1px;
    transition: all 0.2s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
    border-radius: 6px 6px 0 0;
  }
  .tab-icon {
    font-size: 0.95rem;
  }

  .tab-btn:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.02);
  }
  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    background: linear-gradient(to top, rgba(108, 140, 255, 0.1), transparent);
  }

  .tab-panel {
    display: none;
    animation: fadeIn 0.3s ease;
  }
  .tab-panel.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .claim-bar {
      padding: 20px;
    }
    .claim-meta {
      gap: 12px;
    }
    .tab-btn {
      padding: 12px 16px;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  // ─── Tab switching ────────────────────────────────────────────
  document.querySelectorAll(".tab-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tabId = btn.getAttribute("data-tab")!;
      const tabsContainer = btn.closest(".tabs")!;
      const claimSection = tabsContainer.closest(".claim-section")!;

      // Deactivate siblings
      tabsContainer
        .querySelectorAll(".tab-btn")
        .forEach((b) => b.classList.remove("active"));
      claimSection
        .querySelectorAll(".tab-panel")
        .forEach((p) => p.classList.remove("active"));

      // Activate clicked
      btn.classList.add("active");
      document.getElementById(tabId)?.classList.add("active");
    });
  });

  // ─── Search / Filter ──────────────────────────────────────────
  document.querySelectorAll(".search-input").forEach((input) => {
    input.addEventListener("input", () => {
      const tableId = (input as HTMLInputElement).dataset.table!;

      // Check if it's the members table logic or resource table logic based on tableId prefix
      if (tableId.startsWith("members-")) {
        filterMembers(tableId);
      } else {
        filterTable(tableId);
      }
    });
  });

  document.querySelectorAll(".tier-filter").forEach((sel) => {
    sel.addEventListener("change", () => {
      const tableId = (sel as HTMLSelectElement).dataset.table!;
      filterTable(tableId);
    });
  });

  document.querySelectorAll(".tag-filter").forEach((sel) => {
    sel.addEventListener("change", () => {
      const tableId = (sel as HTMLSelectElement).dataset.table!;
      filterTable(tableId);
    });
  });

  function filterTable(tableId: string) {
    const section = document.getElementById(tableId);
    if (!section) return;

    const searchInput = section.querySelector(
      ".search-input",
    ) as HTMLInputElement | null;
    const tierFilter = section.querySelector(
      ".tier-filter",
    ) as HTMLSelectElement | null;
    const tagFilter = section.querySelector(
      ".tag-filter",
    ) as HTMLSelectElement | null;

    const search = searchInput?.value.toLowerCase() ?? "";
    const tier = tierFilter?.value ?? "";
    const tag = tagFilter?.value ?? "";

    const table = section.querySelector("table");
    if (!table) return;

    table.querySelectorAll("tbody tr").forEach((row) => {
      const el = row as HTMLElement;
      const name = el.dataset.name ?? "";
      const rowTier = el.dataset.tier ?? "";
      const rowTag = el.dataset.tag ?? "";

      const matchSearch = !search || name.includes(search);
      const matchTier = !tier || rowTier === tier;
      const matchTag = !tag || rowTag === tag;

      el.style.display = matchSearch && matchTier && matchTag ? "" : "none";
    });
  }

  // ─── Member search & offline toggle ───────────────────────────
  document.querySelectorAll(".show-offline").forEach((cb) => {
    cb.addEventListener("change", () => {
      filterMembers((cb as HTMLInputElement).dataset.table!);
    });
  });

  function filterMembers(tableId: string) {
    // Find the members-section that contains the given table-id
    const section = document
      .querySelector(`table[data-id="${tableId}"]`)
      ?.closest(".members-section");
    if (!section) return;

    const searchInput = section.querySelector(
      ".search-input",
    ) as HTMLInputElement | null;
    const offlineCb = section.querySelector(
      ".show-offline",
    ) as HTMLInputElement | null;

    const search = searchInput?.value.toLowerCase() ?? "";
    const showOffline = offlineCb?.checked ?? true;

    const table = section.querySelector("table");
    if (!table) return;

    table.querySelectorAll("tbody tr").forEach((row) => {
      const el = row as HTMLElement;
      const name = el.dataset.name ?? "";
      const isOnline = el.dataset.online === "true";

      const matchSearch = !search || name.includes(search);
      const matchOnline = showOffline || isOnline;

      el.style.display = matchSearch && matchOnline ? "" : "none";
    });
  }

  // ─── Column sorting ──────────────────────────────────────────
  document.querySelectorAll(".sortable").forEach((th) => {
    th.addEventListener("click", () => {
      const table = th.closest("table")!;
      const tbody = table.querySelector("tbody")!;
      const rows = [...tbody.querySelectorAll("tr")];
      const colIndex = [...th.parentElement!.children].indexOf(th);
      const isNum = th.classList.contains("num");

      // Toggle direction
      const currentDir =
        (th as HTMLElement).dataset.dir === "asc" ? "desc" : "asc";
      (th as HTMLElement).dataset.dir = currentDir;

      rows.sort((a, b) => {
        const aCell = a.children[colIndex]?.textContent?.trim() ?? "";
        const bCell = b.children[colIndex]?.textContent?.trim() ?? "";

        let cmp: number;
        if (isNum) {
          cmp =
            parseFloat(aCell.replace(/,/g, "") || "0") -
            parseFloat(bCell.replace(/,/g, "") || "0");
        } else {
          cmp = aCell.localeCompare(bCell);
        }
        return currentDir === "asc" ? cmp : -cmp;
      });

      for (const row of rows) {
        tbody.appendChild(row);
      }
    });
  });
</script>
