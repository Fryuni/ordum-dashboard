---
import type { ResourceItem, ResourceWithLocations } from "../lib/ordum-data";

interface Props {
  title: string;
  resources: (ResourceItem | ResourceWithLocations)[];
  showLocations?: boolean;
  id: string;
}

const { title, resources, showLocations = false, id } = Astro.props;

// Group by tag for filtering
const allTags = [...new Set(resources.map((r) => r.tag).filter(Boolean))].sort();
const allTiers = [...new Set(resources.map((r) => r.tier))].sort((a, b) => a - b);
---

<div class="resource-section" id={id}>
  <div class="section-header">
    <h3>{title}</h3>
    <span class="badge">{resources.length} types · {resources.reduce((s, r) => s + r.quantity, 0).toLocaleString()} total</span>
  </div>

  <div class="filters">
    <div class="search-input-wrapper">
      <span class="search-icon">🔍</span>
      <input type="text" class="search-input custom-input" placeholder="Search resources..." data-table={id} />
    </div>
    <select class="tier-filter custom-select" data-table={id}>
      <option value="">All Tiers</option>
      {allTiers.map((t) => <option value={String(t)}>Tier {t}</option>)}
    </select>
    <select class="tag-filter custom-select" data-table={id}>
      <option value="">All Tags</option>
      {allTags.map((t) => <option value={t}>{t}</option>)}
    </select>
  </div>

  <div class="table-wrapper">
    <table class="resource-table modern-table" data-id={id}>
      <thead>
        <tr>
          <th class="sortable" data-sort="name">Name ↕</th>
          <th class="sortable num" data-sort="quantity">Qty ↕</th>
          <th class="sortable num" data-sort="tier">Tier ↕</th>
          <th>Tag</th>
          <th>Rarity</th>
          {showLocations && <th>Locations</th>}
        </tr>
      </thead>
      <tbody>
        {resources.map((r) => {
          const locs = 'locations' in r ? (r as ResourceWithLocations).locations : [];
          return (
            <tr data-name={r.name.toLowerCase()} data-tier={r.tier} data-tag={r.tag}>
              <td class="item-name">
                <span class={`rarity-dot rarity-${(r.rarity ?? 'Common').toLowerCase()}`} />
                {r.name}
              </td>
              <td class="num font-mono">{r.quantity.toLocaleString()}</td>
              <td class="num tier-cell">
                <span class={`tier-badge tier-${r.tier}`}>T{r.tier}</span>
              </td>
              <td class="tag-cell"><span class="tag-pill">{r.tag}</span></td>
              <td class="rarity-cell">{r.rarity ?? '—'}</td>
              {showLocations && (
                <td class="locations-cell">
                  {locs.length > 0 && (
                    <details class="loc-details">
                      <summary>{locs.length} location{locs.length > 1 ? 's' : ''}</summary>
                      <ul class="location-list">
                        {locs.map((l) => (
                          <li>
                            <span class={`loc-type loc-${l.owner_type.toLowerCase()}`}>
                              {l.owner_type === 'Building' ? '🏠' : '👤'}
                            </span>
                            <span class="loc-name">{l.building_name ?? l.owner_name ?? l.owner_type}</span>
                            <span class="loc-qty font-mono">×{l.quantity}</span>
                          </li>
                        ))}
                      </ul>
                    </details>
                  )}
                </td>
              )}
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>

<style>
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .section-header h3 {
    font-size: 1.1rem;
    color: var(--text);
    margin: 0;
  }
  .badge {
    background: var(--bg-surface-3);
    color: var(--text-muted);
    padding: 4px 10px;
    border-radius: 16px;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--border);
  }

  .filters {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 260px;
    max-width: 400px;
  }
  .search-icon {
    position: absolute;
    left: 10px;
    font-size: 0.9rem;
    pointer-events: none;
    color: var(--text-muted);
  }
  .custom-input, .custom-select {
    background: var(--bg-surface-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    height: 34px;
    color: var(--text);
    font-size: 0.85rem;
    outline: none;
    transition: all 0.2s ease;
  }
  .custom-input {
    width: 100%;
    padding: 0 16px 0 44px;
  }
  .custom-select {
    padding: 0 16px;
    min-width: 160px;
    cursor: pointer;
  }
  .custom-input:focus, .custom-select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .table-wrapper {
    overflow-x: auto;
    background: var(--bg-surface-2);
    border-radius: 8px;
    border: 1px solid var(--border);
    margin-bottom: 24px;
  }

  .modern-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .modern-table th {
    background: rgba(26, 31, 46, 0.8);
    backdrop-filter: blur(8px);
    padding: 10px 12px;
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--border);
  }
  .modern-table th.num, .modern-table td.num { text-align: right; }
  .modern-table td {
    padding: 8px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    font-size: 0.85rem;
    vertical-align: middle;
  }
  .modern-table tbody tr:last-child td {
    border-bottom: none;
  }
  .modern-table tbody tr {
    transition: background 0.2s;
  }
  .modern-table tbody tr:hover {
    background: var(--bg-surface-3);
  }
  .sortable { cursor: pointer; user-select: none; transition: color 0.2s; }
  .sortable:hover { color: var(--accent); }

  .item-name {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 500;
  }
  .rarity-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .rarity-common { background: var(--rarity-common); }
  .rarity-uncommon { background: var(--rarity-uncommon); }
  .rarity-rare { background: var(--rarity-rare); }
  .rarity-epic { background: var(--rarity-epic); }
  .rarity-legendary { background: var(--rarity-legendary); }

  .font-mono { font-family: monospace; font-size: 0.95rem; }

  .tier-badge {
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .tier-1 { background: #374151; color: #d1d5db; }
  .tier-2 { background: #1e3a2f; color: #6ee7b7; }
  .tier-3 { background: #1e2a3f; color: #93c5fd; }
  .tier-4 { background: #2d1f3f; color: #c4b5fd; }
  .tier-5 { background: #3f2d1f; color: #fcd34d; }
  .tier--1, .tier-0 { background: #2d2d2d; color: #9ca3af; }

  .tag-pill {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .loc-details summary {
    cursor: pointer;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 500;
    user-select: none;
    outline: none;
  }
  .loc-details summary:hover { text-decoration: underline; }
  .location-list {
    list-style: none;
    margin-top: 8px;
    padding: 8px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.85rem;
  }
  .location-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .location-list li:last-child { border-bottom: none; }
  .loc-name { flex: 1; color: var(--text-muted); }
  .loc-qty { color: var(--accent-4); font-weight: 600; }
</style>
