{
  "name": "ordum-dashboard",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "concurrently -n worker,vite -c blue,green \"wrangler dev\" \"vite\"",
    "dev:worker": "wrangler dev",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "wrangler dev --assets dist/client",
    "deploy": "vite build && wrangler deploy",
    "validate": "tsc --noEmit",
    "format": "prettier -w .",
    "db:reset": "rm -rf .wrangler/state/v3/d1",
    "db:ingest": "curl -s -X POST 'http://localhost:8787/api/storage-audit/ingest?claim=1224979098661645606'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@croct/cache": "^0.5.1",
    "@nanostores/async": "^0.1.0",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/preact": "^1.1.0",
    "@nanostores/router": "^1.0.0",
    "devalue": "^5.6.4",
    "hono": "^4.12.10",
    "kysely": "^0.28.15",
    "kysely-d1": "^0.4.0",
    "lightweight-charts": "^5.1.0",
    "nanostores": "^1.0.0",
    "ohash": "^2.0.11",
    "preact": "^10.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260402.1",
    "@preact/preset-vite": "^2.10.4",
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "nanostores": "$nanostores"
  }
}
