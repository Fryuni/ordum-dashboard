{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowJs": true,
    "outDir": "./_generated",
    "resolveJsonModule": true
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
